# ============================================================================
# graph-core .gitignore
# ============================================================================

# Carpetas de compilación y distribución
build*/
_build*/
dist/
release/

# Archivos generados por CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
_deps/
compile_commands.json
*.cmake
!mingw-toolchain.cmake

# IDE y editores
.vscode/
.idea/
*.swp
*.swo
*~
.history/
.cache/

# Archivos compilados y binarios
*.o
*.exe
*.out
*.a
*.so
*.dylib
graph-core

# Archivos del SO
.DS_Store
Thumbs.db

# Herramientas de desarrollo (opencode, atl, agents, etc.)
openspec/
.atl/
.opencode/
agents/
.agents/

# Configuración en tiempo de ejecución
imgui.ini
*.log

# ============================================================================
# Excepciones explícitas (SI deben ir al repo)
# ============================================================================
!muestras/
!recursos/
!graph-core-logo.png
!build-all.sh
registro de cambios y correciones.md
